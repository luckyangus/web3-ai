# ============================================================
# AI模型配置
# ============================================================
# AI API密钥（用于调用AI分析服务）
AI_API_KEY=
# AI服务的基础URL地址
AI_BASE_URL=
# 使用的AI模型名称
AI_MODEL=mimo-v2-omni

# ============================================================
# OKX交易所配置
# ============================================================
# OKX交易所API密钥
OKX_API_KEY=
# OKX交易所API密钥
OKX_SECRET=
# OKX交易所交易密码
OKX_PASSWORD=

# ============================================================
# 交易配置
# ============================================================
# 交易对符号（格式：基础货币/计价货币:结算货币）
TRADE_SYMBOL=BTC/USDT:USDT
# 每次交易的数量（单位：BTC）
TRADE_AMOUNT=0.08
# 杠杆倍数（1-125倍）
TRADE_LEVERAGE=10
# K线时间周期（1m=1分钟, 5m=5分钟, 15m=15分钟, 1h=1小时）
TRADE_TIMEFRAME=15m
# 测试模式（true=模拟交易, false=实盘交易）
TEST_MODE=true

# ============================================================
# 多仓策略配置
# ============================================================
# 最大持仓数量（同时持有的最大仓位数）
MAX_POSITIONS=5
# 止损百分比（亏损达到此百分比时自动平仓）
STOP_LOSS_PERCENT=1.5
# 止盈百分比（盈利达到此百分比时自动平仓）
TAKE_PROFIT_PERCENT=3.0

# ============================================================
# RSI指标阈值配置
# ============================================================
# RSI超卖阈值（RSI低于此值时考虑做多）
RSI_OVERSOLD_THRESHOLD=35
# RSI超买阈值（RSI高于此值时考虑做空）
RSI_OVERBOUGHT_THRESHOLD=65
# 同方向最大持仓数（同一方向最多持有的仓位数量）
MAX_SAME_DIRECTION_POSITIONS=3

# ============================================================
# 数据分析配置
# ============================================================
# 获取的K线数据点数量
KLINE_DATA_POINTS=96
# 发送给AI分析的K线数量
KLINE_FOR_AI=10
# 显示的最近交易记录数量
RECENT_TRADES_COUNT=10
# 交易历史记录保存上限
TRADE_HISTORY_LIMIT=200
# 决策间隔时间（分钟）
DECISION_INTERVAL=15

# ============================================================
# 策略模式配置
# ============================================================
# 交易策略模式（aggressive=激进, standard=标准, conservative=保守）
STRATEGY_MODE=aggressive
# 激进模式RSI阈值（宽松阈值，更频繁交易）
AGGRESSIVE_RSI_OVERSOLD=20
AGGRESSIVE_RSI_OVERBOUGHT=80
# 标准模式RSI阈值（标准阈值，平衡交易）
STANDARD_RSI_OVERSOLD=35
STANDARD_RSI_OVERBOUGHT=65
# 保守模式RSI阈值（严格阈值，稳健交易）
CONSERVATIVE_RSI_OVERSOLD=40
CONSERVATIVE_RSI_OVERBOUGHT=60

# ============================================================
# 策略模式风控参数（可选配置）
# ============================================================
# 激进模式参数（高风险高收益，高频交易）
AGGRESSIVE_STOP_LOSS=1.5
AGGRESSIVE_TAKE_PROFIT=5.0
AGGRESSIVE_DECISION_INTERVAL=2
# 标准模式参数（平衡风险收益，适中频率）
STANDARD_STOP_LOSS=2.0
STANDARD_TAKE_PROFIT=4.0
STANDARD_DECISION_INTERVAL=10
# 保守模式参数（低风险稳健，低频交易）
CONSERVATIVE_STOP_LOSS=2.5
CONSERVATIVE_TAKE_PROFIT=3.0
CONSERVATIVE_DECISION_INTERVAL=20

# ============================================================
# Web面板配置
# ============================================================
# Web服务器监听地址（0.0.0.0表示允许所有IP访问）
WEB_HOST=0.0.0.0
# Web服务器监听端口
WEB_PORT=5001
# Web面板会话密钥（用于用户认证）
WEB_SECRET_KEY=yuzeangusjustlikemaybe
